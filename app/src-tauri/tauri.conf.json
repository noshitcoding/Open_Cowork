{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Open Cowork",
  "version": "0.1.0",
  "identifier": "io.noshitcoding.opencowork",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/32x32.png"
    },
    "windows": [
      {
        "title": "Open Cowork",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "resources/pdfium/bin/pdfium.dll",
      "resources/pdfium/LICENSE",
      "resources/pdfium/VERSION",
      "python/crew_runtime/main.py",
      "python/crew_runtime/requirements.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
