{
  "name": "localai-cowork",
  "private": true,
  "version": "0.1.8",
  "description": "Open-source, local-first AI coworker for Windows with Ollama, MCP, tasks, approvals, and tools.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/noshitcoding/LocalAI-Cowork.git"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:tauri": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "preview:tauri": "npm run build && vite preview --host 127.0.0.1 --port 5173 --strictPort",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "doctor": "node ./scripts/doctor.mjs",
    "doctor:ci": "node ./scripts/doctor.mjs --ci",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "budgets:build": "node ./scripts/check-budgets.mjs",
    "brand:assets": "node ./scripts/generate-brand-assets.mjs",
    "brand:verify": "node ./scripts/verify-carbon-signal.mjs",
    "marketing:screenshot": "npm run build && node ./scripts/capture-marketing-preview.mjs",
    "installer": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-installer.ps1",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "smoke:desktop": "node ./scripts/desktop-smoke.mjs",
    "smoke:authenticode": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/authenticode-smoke.ps1",
    "security:npm": "npm audit --audit-level=high",
    "supply-chain:check": "node ./scripts/supply-chain.mjs check",
    "supply-chain:sbom": "node ./scripts/supply-chain.mjs sbom",
    "supply-chain:release": "node ./scripts/supply-chain.mjs release",
    "tauri": "tauri",
    "test": "vitest",
    "test:scripts": "node --test ./scripts/process-utils.test.mjs ./scripts/supply-chain.test.mjs",
    "test:ci": "vitest run",
    "test:ui": "npm run build && npm run budgets:build && playwright test",
    "test:ui:update": "npm run build && npm run budgets:build && playwright test --update-snapshots",
    "i18n:audit": "node ./scripts/i18n-audit.mjs",
    "verify": "node ./scripts/verify.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-notification": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
