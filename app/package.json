{
  "name": "open-cowork",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first desktop workspace for agentic work with Ollama, MCP, tasks, and tools.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/noshitcoding/Open_Cowork.git"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:tauri": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "preview:tauri": "npm run build && vite preview --host 127.0.0.1 --port 5173 --strictPort",
    "doctor": "node ./scripts/doctor.mjs",
    "doctor:ci": "node ./scripts/doctor.mjs --ci",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "budgets:build": "node ./scripts/check-budgets.mjs",
    "installer": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-installer.ps1",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "smoke:desktop": "node ./scripts/desktop-smoke.mjs",
    "tauri": "tauri",
    "test": "vitest",
    "test:ci": "vitest run",
    "i18n:audit": "node ./scripts/i18n-audit.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
