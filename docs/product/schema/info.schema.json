{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Cowork Product Info Element",
  "type": "object",
  "required": [
    "id",
    "owner_element",
    "type",
    "visible_when",
    "copy_key",
    "source_of_value",
    "severity",
    "freshness",
    "accessibility"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^info:" },
    "owner_element": { "type": "string", "pattern": "^element:" },
    "type": { "type": "string" },
    "visible_when": { "type": "string" },
    "copy_key": { "type": "string" },
    "source_of_value": { "type": "string" },
    "severity": { "type": "string" },
    "freshness": { "type": "string" },
    "accessibility": { "type": "string" }
  }
}
