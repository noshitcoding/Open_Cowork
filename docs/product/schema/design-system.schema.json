{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Cowork Design System Reference",
  "type": "object",
  "required": [
    "id",
    "title",
    "purpose",
    "primitives",
    "status_tokens",
    "rules",
    "known_exceptions",
    "source_files",
    "tests"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^design-system:" },
    "title": { "type": "string" },
    "purpose": { "type": "string" },
    "primitives": { "type": "array", "items": { "type": "string" } },
    "status_tokens": { "type": "array", "items": { "type": "string" } },
    "rules": { "type": "array", "items": { "type": "string" } },
    "known_exceptions": { "type": "array", "items": { "type": "string" } },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } }
  }
}
