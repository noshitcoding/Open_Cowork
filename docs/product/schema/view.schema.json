{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Cowork Product View",
  "type": "object",
  "required": [
    "id",
    "route",
    "title",
    "purpose",
    "user_story",
    "layout_regions",
    "owned_elements",
    "primary_actions",
    "empty_states",
    "loading_states",
    "error_states",
    "data_dependencies",
    "permissions",
    "source_files",
    "tests"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^view:" },
    "route": { "type": "string" },
    "title": { "type": "string" },
    "purpose": { "type": "string" },
    "user_story": { "type": "string" },
    "layout_regions": { "type": "array", "items": { "type": "string" } },
    "owned_elements": { "type": "array", "items": { "type": "string", "pattern": "^element:" } },
    "primary_actions": { "type": "array", "items": { "type": "string", "pattern": "^button:" } },
    "empty_states": { "type": "array", "items": { "type": "string" } },
    "loading_states": { "type": "array", "items": { "type": "string" } },
    "error_states": { "type": "array", "items": { "type": "string" } },
    "data_dependencies": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } }
  }
}
